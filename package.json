{
  "name": "handyman-frontend",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=admin-web",
    "dev:mobile": "turbo dev --filter=mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "gen:api": "openapi-typescript ./openapi.json -o packages/api/src/schema.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.1",
    "turbo": "^2.8.13",
    "typescript": "^5.5.4"
  }
}