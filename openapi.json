  "components": {
    "schemas": {
      "AvailabilitySlot": {
        "properties": {
          "start": {
            "type": "string",
            "title": "Start"
          },
          "end": {
            "type": "string",
            "title": "End"
          }
        },
        "type": "object",
        "required": [
          "start",
          "end"
        ],
        "title": "AvailabilitySlot"
      },
      "BookingResponse": {
        "properties": {
          "booking_id": {
            "type": "string",
            "title": "Booking Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "user_email": {
            "type": "string",
            "title": "User Email"
          },
          "handyman_email": {
            "type": "string",
            "title": "Handyman Email"
          },
          "desired_start": {
            "type": "string",
            "format": "date-time",
            "title": "Desired Start"
          },
          "desired_end": {
            "type": "string",
            "format": "date-time",
            "title": "Desired End"
          },
          "failure_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Reason"
          },
          "cancellation_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cancellation Reason"
          }
        },
        "type": "object",
        "required": [
          "booking_id",
          "status",
          "user_email",
          "handyman_email",
          "desired_start",
          "desired_end"
        ],
        "title": "BookingResponse"
      },
      "CancelBookingRequest": {
        "properties": {
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason",
            "default": "user_requested"
          }
        },
        "type": "object",
        "title": "CancelBookingRequest"
      },
      "CancelBookingResponse": {
        "properties": {
