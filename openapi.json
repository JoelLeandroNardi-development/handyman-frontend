            "type": "string",
            "title": "Booking Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "cancellation_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cancellation Reason"
          }
        },
        "type": "object",
        "required": [
          "booking_id",
